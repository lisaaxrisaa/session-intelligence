{
  "name": "session-intelligence",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"node --env-file=.env --import=tsx --watch server/index.ts\"",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "start": "node --env-file=.env --import=tsx server/index.ts",
    "type-check": "vue-tsc -b"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@supabase/supabase-js": "^2.49.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "vue": "^3.5.25"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vue/tsconfig": "^0.8.1",
    "concurrently": "^9.1.2",
    "tsx": "^4.19.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vue-tsc": "^3.1.5"
  }
}
